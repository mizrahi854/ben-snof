rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check admin via custom claim OR allow-list document
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Public reads, writes if authenticated
    match /services/{id}    { allow read: if true; allow write: if request.auth != null; }
    match /barbers/{id}     { allow read: if true; allow write: if request.auth != null; }
    match /gallery/{id}     { allow read: if true; allow write: if request.auth != null; }
    match /settings/{id}    { allow read: if true; allow write: if request.auth != null; }

    // Users own their profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Appointments: user can read/create/delete own; authenticated full
    match /appointments/{id} {
      allow read:   if request.auth != null && (resource.data.userId == request.auth.uid || request.auth != null);
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Admins list
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
